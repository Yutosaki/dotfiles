{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
{{ else -}}
#!/bin/zsh
{{ end -}}

# エラーが発生したら即座にスクリプトを停止する
set -e

# root権限チェック
SUDO_CMD=""
if [ "$(id -u)" -ne 0 ]; then
    SUDO_CMD="sudo"
fi

echo "🚀 セットアップを開始します..."

# -----------------------------------------------------------------------------
# 1. OS固有の基盤パッケージインストール
# -----------------------------------------------------------------------------
{{ if eq .chezmoi.os "linux" -}}
echo "🐧 Linux用のセットアップを実行中..."
export DEBIAN_FRONTEND=noninteractive

# 必須ツールインストール
$SUDO_CMD apt-get update
$SUDO_CMD apt-get install -y \
    build-essential unzip valgrind git curl zsh tmux tzdata locales

# ロケール生成
if ! command -v locale-gen &> /dev/null; then
    $SUDO_CMD apt-get update
    $SUDO_CMD apt-get install -y locales
fi
# en_US.UTF-8 がない場合は生成
if ! grep -q "en_US.UTF-8" /etc/locale.gen; then
    echo "en_US.UTF-8 UTF-8" | $SUDO_CMD tee -a /etc/locale.gen
fi
$SUDO_CMD locale-gen en_US.UTF-8

# タイムゾーン設定
if [ ! -f /etc/localtime ]; then
    echo "⏰ タイムゾーンを Asia/Tokyo に設定..."
    $SUDO_CMD ln -fs /usr/share/zoneinfo/Asia/Tokyo /etc/localtime
    echo "Asia/Tokyo" | $SUDO_CMD tee /etc/timezone
    $SUDO_CMD dpkg-reconfigure --frontend noninteractive tzdata
fi

{{ else if eq .chezmoi.os "darwin" -}}
echo "🍎 macOS用のセットアップを実行中..."
if ! command -v brew &> /dev/null; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
# llvm, cmake, ninja は mise でのビルド失敗を避けるために brew で入れておく
brew install git zsh tmux llvm cmake ninja
{{ end -}}

# -----------------------------------------------------------------------------
# 2. mise によるツール一括インストール (Neovim, Rust, Node, etc.)
# -----------------------------------------------------------------------------
MISE_BIN="$HOME/.local/bin/mise"

if [ ! -f "$MISE_BIN" ]; then
    echo "🪄 Installing mise..."
    curl https://mise.jdx.dev/install.sh | sh
fi

# どんなサブプロセス（npm等）からも絶対に見えるように、システムパスにリンクを張る
if ! command -v mise &> /dev/null; then
    if [ -d "/usr/local/bin" ]; then
        $SUDO_CMD ln -sf "$MISE_BIN" /usr/local/bin/mise
    fi
fi

# 基本のPATHエクスポート（手動用）
export PATH="$HOME/.local/bin:$HOME/.local/share/mise/shims:$PATH"

# 現在のスクリプトセッションに mise の機能を完全にフックさせる
{{ if eq .chezmoi.os "linux" -}}
eval "$($MISE_BIN activate bash)"
{{ else -}}
eval "$($MISE_BIN activate zsh)"
{{ end -}}

echo "🛠️ mise install を実行中..."
# インストール実行（パスもフックも完了しているので npm も迷子になりません）
mise install -y

# パスの再構成
mise reshim

# -----------------------------------------------------------------------------
# 3. Zsh/Tmux プラグイン
# -----------------------------------------------------------------------------
ZSH_PLUGIN_DIR="$HOME/.local/share/zsh/plugins"
mkdir -p "$ZSH_PLUGIN_DIR"

clone_if_not_exists() {
    REPO_URL=$1; DEST_DIR=$2
    if [ ! -d "$DEST_DIR" ]; then 
        echo "⬇️ Cloning $DEST_DIR..."
        git clone --depth 1 "$REPO_URL" "$DEST_DIR"
    fi
}

clone_if_not_exists "https://github.com/zsh-users/zsh-syntax-highlighting.git" "$ZSH_PLUGIN_DIR/zsh-syntax-highlighting"
clone_if_not_exists "https://github.com/zsh-users/zsh-autosuggestions" "$ZSH_PLUGIN_DIR/zsh-autosuggestions"
clone_if_not_exists "https://github.com/Aloxaf/fzf-tab" "$ZSH_PLUGIN_DIR/fzf-tab"

# --- Tmux プラグインマネージャー (tpm) ---
TMUX_TPM_DIR="$HOME/.tmux/plugins/tpm"
clone_if_not_exists "https://github.com/tmux-plugins/tpm" "$TMUX_TPM_DIR"

# -----------------------------------------------------------------------------
# 4. 仕上げ
# -----------------------------------------------------------------------------
ZSH_PATH=$(command -v zsh)
CURRENT_USER=$(whoami)

# OSごとに「システムに登録されている現在のデフォルトシェル」を正確に取得
{{ if eq .chezmoi.os "darwin" -}}
CURRENT_DEFAULT_SHELL=$(dscl . -read /Users/$CURRENT_USER UserShell | awk '{print $2}')
{{ else -}}
CURRENT_DEFAULT_SHELL=$(getent passwd $CURRENT_USER | cut -d: -f7)
{{ end -}}

# 登録されているシェルが目的のZshパスと違う場合のみ変更処理を行う
if [ "$CURRENT_DEFAULT_SHELL" != "$ZSH_PATH" ]; then
    echo "🐚 Changing default shell to $ZSH_PATH..."

    # 新しいzshのパスが /etc/shells に登録されていない場合は追加する (chshエラー回避のため)
    if ! grep -Fxq "$ZSH_PATH" /etc/shells; then
        echo "追加: $ZSH_PATH を /etc/shells に登録します..."
        echo "$ZSH_PATH" | $SUDO_CMD tee -a /etc/shells
    fi

    $SUDO_CMD chsh -s "$ZSH_PATH" "$CURRENT_USER"
fi

echo "✨ Setup Complete!"
