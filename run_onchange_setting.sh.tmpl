{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
{{ else -}}
#!/bin/zsh
{{ end -}}

# エラーが発生したら即座にスクリプトを停止する
set -e

# root権限チェック
SUDO_CMD=""
if [ "$(id -u)" -ne 0 ]; then
    SUDO_CMD="sudo"
fi

echo "🚀 セットアップを開始します..."

# -----------------------------------------------------------------------------
# 1. Linux用セットアップ (ロケール・ツール・Neovim)
# -----------------------------------------------------------------------------
{{ if eq .chezmoi.os "linux" -}}
echo "🐧 Linux用のセットアップを実行中..."
export DEBIAN_FRONTEND=noninteractive

# 必須ツールインストール
$SUDO_CMD apt-get update
$SUDO_CMD apt-get install -y \
    build-essential unzip valgrind git curl zsh tmux tzdata locales \
    ripgrep bat nodejs npm

# ロケール生成 (LC_ALLエラー対策)
if ! command -v locale-gen &> /dev/null; then
    $SUDO_CMD apt-get update
    $SUDO_CMD apt-get install -y locales
fi
# en_US.UTF-8 がない場合は生成
if ! grep -q "en_US.UTF-8" /etc/locale.gen; then
    echo "en_US.UTF-8 UTF-8" | $SUDO_CMD tee -a /etc/locale.gen
fi
$SUDO_CMD locale-gen en_US.UTF-8

# タイムゾーン設定
if [ ! -f /etc/localtime ]; then
    echo "⏰ タイムゾーンを Asia/Tokyo に設定..."
    $SUDO_CMD ln -fs /usr/share/zoneinfo/Asia/Tokyo /etc/localtime
    echo "Asia/Tokyo" | $SUDO_CMD tee /etc/timezone
    $SUDO_CMD dpkg-reconfigure --frontend noninteractive tzdata
fi

# batcat対応
if command -v batcat &> /dev/null && ! command -v bat &> /dev/null; then
    mkdir -p ~/.local/bin
    ln -s /usr/bin/batcat ~/.local/bin/bat
    export PATH="$HOME/.local/bin:$PATH"
fi

# --- Neovim (指定インストール) ---
NVIM_VERSION="v0.11.6"

# インストール済みか、かつ指定バージョンと同じかチェック
if ! command -v nvim &> /dev/null || ! nvim --version | grep -q "$NVIM_VERSION"; then
    echo "🌑 Installing Neovim $NVIM_VERSION ..."

    ARCH=$(uname -m)
    # GitHubのリリースアセット名に合わせる
    if [ "$ARCH" = "x86_64" ]; then
        NVIM_ASSET="nvim-linux-x86_64.tar.gz"
        NVIM_DIR_NAME="nvim-linux-x86_64"
    elif [ "$ARCH" = "aarch64" ]; then
        NVIM_ASSET="nvim-linux-arm64.tar.gz"
        NVIM_DIR_NAME="nvim-linux-arm64"
    else
        echo "❌ Unsupported architecture: $ARCH"
        exit 1
    fi

    URL="https://github.com/neovim/neovim/releases/download/${NVIM_VERSION}/${NVIM_ASSET}"
    echo "⬇️ Downloading from: $URL"

    # 一時ディレクトリで作業
    TEMP_DIR=$(mktemp -d)
    cd "$TEMP_DIR"

    if curl -L -f -O "$URL"; then
        # 既存の古いバイナリディレクトリを削除してクリーンアップ
        $SUDO_CMD rm -rf "/opt/$NVIM_DIR_NAME"
        
        # 解凍して配置
        $SUDO_CMD tar -C /opt -xzf "$NVIM_ASSET"
        
        # シンボリックリンクの作成（絶対パスで指定して確実に）
        $SUDO_CMD ln -sf "/opt/$NVIM_DIR_NAME/bin/nvim" /usr/local/bin/nvim
        
        echo "✅ Neovim $NVIM_VERSION installed successfully."
    else
        echo "❌ Download failed! Check if version $NVIM_VERSION exists at GitHub."
    fi
    
    # 作業ディレクトリの削除
    cd - > /dev/null
    rm -rf "$TEMP_DIR"
else
    echo "✅ Neovim is already up-to-date ($(nvim --version | head -n 1))."
fi

{{ else if eq .chezmoi.os "darwin" -}}
# -----------------------------------------------------------------------------
# 2. macOS用セットアップ
# -----------------------------------------------------------------------------
echo "🍎 macOS用のセットアップを実行中..."
if ! command -v brew &> /dev/null; then
    echo "🍺 Homebrew not found. Skipping brew install."
else
    echo "🍺 Updating Homebrew..."
    brew update || true

    echo "🍺 Installing packages..."
    brew install lsd bat ripgrep tmux neovim node || true
fi
    
{{ end -}}

# -----------------------------------------------------------------------------
# 3. 共通処理: Rust & Zsh/Tmux プラグイン
# -----------------------------------------------------------------------------
if ! command -v cargo &> /dev/null; then
    echo "🦀 Rustをインストール中..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    source "$HOME/.cargo/env"
fi

if ! command -v rg &> /dev/null; then cargo install ripgrep; fi
if ! command -v lsd &> /dev/null; then cargo install lsd; fi
if ! command -v bat &> /dev/null; then cargo install bat; fi

# Zshプラグイン保存先
ZSH_PLUGIN_DIR="$HOME/.local/share/zsh/plugins"
mkdir -p "$ZSH_PLUGIN_DIR"

clone_if_not_exists() {
    REPO_URL=$1; DEST_DIR=$2
    if [ ! -d "$DEST_DIR" ]; then 
        echo "⬇️ Cloning $DEST_DIR..."
        git clone --depth 1 "$REPO_URL" "$DEST_DIR"
    fi
}

clone_if_not_exists "https://github.com/zsh-users/zsh-syntax-highlighting.git" "$ZSH_PLUGIN_DIR/zsh-syntax-highlighting"
clone_if_not_exists "https://github.com/zsh-users/zsh-autosuggestions" "$ZSH_PLUGIN_DIR/zsh-autosuggestions"
clone_if_not_exists "https://github.com/Aloxaf/fzf-tab" "$ZSH_PLUGIN_DIR/fzf-tab"

# --- Tmux プラグインマネージャー (tpm) ---
TMUX_TPM_DIR="$HOME/.tmux/plugins/tpm"
clone_if_not_exists "https://github.com/tmux-plugins/tpm" "$TMUX_TPM_DIR"

FZF_DIR="$HOME/.fzf"
if [ ! -d "$FZF_DIR" ]; then
    git clone --depth 1 https://github.com/junegunn/fzf.git "$FZF_DIR"
    "$FZF_DIR/install" --all --no-bash --no-fish
fi

# デフォルトシェルを Zsh に変更 (GitHub Actions対策で sudo を使用)
ZSH_PATH=$(which zsh)
CURRENT_USER=$(whoami)
if [ "$SHELL" != "$(which zsh)" ]; then
    echo "🐚 Changing default shell to zsh..."
    $SUDO_CMD chsh -s "$(which zsh)" "$CURRENT_USER"
fi

echo "✨ Setup Complete!"
echo "✨ セットアップ完了！"
